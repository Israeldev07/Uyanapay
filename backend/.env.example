# Conexión principal (escritura) - PostgreSQL master
DATABASE_URL="postgresql://uyanapay:uyanapay@localhost:5432/uyanapay?schema=public"

# Read replica dedicada (lecturas de alto volumen: catálogo, historial, estadísticas)
DATABASE_REPLICA_URL="postgresql://uyanapay:uyanapay@localhost:5433/uyanapay?schema=public"

# Autenticación
JWT_SECRET="cambia-este-secreto-en-produccion"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=4000
CORS_ORIGIN="http://localhost:3000"

# Negocio
COMMISSION_RATE=0.10
