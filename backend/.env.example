# === Base de datos (Supabase / PostgreSQL) ===
# Copia este archivo a .env y reemplaza [USUARIO], [PASSWORD] y [HOST].
# En Supabase: Project Settings → Database → Connection string → "Prisma".

# Conexión de la app (runtime): pooler transaccional, puerto 6543
DATABASE_URL="postgresql://[USUARIO]:[PASSWORD]@[HOST].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Conexión directa para migraciones y seed (session pooler), puerto 5432
DIRECT_URL="postgresql://[USUARIO]:[PASSWORD]@[HOST].pooler.supabase.com:5432/postgres"

# === Autenticación ===
JWT_SECRET="cambia-este-secreto-en-produccion"
JWT_EXPIRES_IN="7d"

# === Servidor ===
PORT=4000
CORS_ORIGIN="http://localhost:3000"

# === Negocio ===
COMMISSION_RATE=0.10
